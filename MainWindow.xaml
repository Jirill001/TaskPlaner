<Window x:Class="TaskPlaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:views="clr-namespace:TaskPlaner.Views"
        xmlns:models="clr-namespace:TaskPlaner.Models"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Планировщик задач с диаграммой Ганта" 
        Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="250"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="10">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Фильтр по статусу:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="FilterComboBox" 
                          ItemsSource="{Binding FilterStatusesList}"
                          SelectedValue="{Binding FilterStatus}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Key"
                          Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <Button Content="Добавить" Command="{Binding AddTaskCommand}" 
                            Width="80" Margin="0,0,5,0"/>
                    <Button Content="Изменить" Command="{Binding EditTaskCommand}" 
                            Width="80" Margin="0,0,5,0"/>
                    <Button Content="Удалить" Command="{Binding DeleteTaskCommand}" 
                            Width="80"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                            Width="80" Margin="0,0,5,0"/>
                    <Button Content="Загрузить" Command="{Binding LoadCommand}" 
                            Width="80"/>
                </StackPanel>
                <Button Content="Авто-расстановка" Command="{Binding AutoScheduleCommand}" 
                        Width="152" Margin="0,10,0,0" Height="21"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding TasksView}" 
         SelectedItem="{Binding SelectedTask}"
         DockPanel.Dock="Top">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2">
                            
                            <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:Status.Planned}">
                                                <Setter Property="Fill" Value="Gray"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:Status.InProgress}">
                                                <Setter Property="Fill" Value="DodgerBlue"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:Status.Completed}">
                                                <Setter Property="Fill" Value="LimeGreen"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            
                            <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="5,0,0,0">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:Priority.Low}">
                                                <Setter Property="Fill" Value="LightGreen"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:Priority.Medium}">
                                                <Setter Property="Fill" Value="Gold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:Priority.High}">
                                                <Setter Property="Fill" Value="Crimson"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <TextBlock Text="{Binding Title}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                      Background="Gray" ResizeBehavior="PreviousAndNext"/>

        <views:GanttChartView x:Name="ganttChartView" Grid.Column="2" Tasks="{Binding Tasks}" Margin="10"/>
        
    </Grid>
</Window>
